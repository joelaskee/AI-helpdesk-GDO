# Copia in .env e personalizza se serve

# LLM (Ollama sul Mac host)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=ministral3

# Trascrizione: faster-whisper | voxtral
TRANSCRIBE_ENGINE=faster-whisper
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=int8

# Quando porti il progetto sul PC con Voxtral+vLLM:
# TRANSCRIBE_ENGINE=voxtral
# VOXTRAL_BASE_URL=http://host.docker.internal:8000/v1
# VOXTRAL_MODEL=mistralai/Voxtral-Small-24B-2507
